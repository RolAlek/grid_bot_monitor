{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🧹Clean caches",
      "type": "shell",
      "command": "uvx pyclean .",
      "icon": {
        "color": "terminal.ansiYellow",
        "id": "wrench"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Runs pyclean for clean python caches files and directories"
    },
    {
      "label": "🧹 Lint & Fix",
      "type": "shell",
      "command": "uvx ruff check . --fix || uvx ruff format .",
      "icon": {
        "color": "terminal.ansiYellow",
        "id": "wrench"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Runs ruff to lint and auto-fix your code."
    },
    {
      "label": "🔍 Mypy type check",
      "type": "shell",
      "command": "uvx mypy .",
      "icon": {
        "color": "terminal.ansiBlue",
        "id": "search"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Performs static type checking using mypy."
    },
    {
      "label": "📦 Install Dependencies",
      "type": "shell",
      "command": "uv init",
      "icon": {
        "color": "terminal.ansiCyan",
        "id": "package"
      },
      "problemMatcher": [],
      "detail": "Installs project dependencies via UV."
    },
    {
      "label": "🔒 Install Pre-commit Hooks",
      "type": "shell",
      "command": "uv run pre-commit install",
      "icon": {
        "color": "terminal.ansiRed",
        "id": "lock"
      },
      "problemMatcher": [],
      "detail": "Installs pre-commit hooks for the project."
    },
    {
      "label": "Setup Environment",
      "dependsOn": ["📦 Install Dependencies", "🔒 Install Pre-commit Hooks"],
      "icon": {
        "color": "terminal.ansiGreen",
        "id": "gear"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "reveal": "always",
        "focus": true,
        "close": false,
        "echo": true,
        "showReuseMessage": true
      },
      "problemMatcher": [],
      "detail": "Sets up the development environment by installing dependencies and pre-commit hooks."
    },
    {
      "label": "📦 Apply Migrations",
      "type": "shell",
      "command": "python -m source exec migrations",
      "icon": {
        "color": "terminal.ansiYellow",
        "id": "database"
      },
      "presentation": {
        "panel": "dedicated",
        "clear": true,
        "reveal": "always",
        "focus": true,
        "echo": true
      },
      "problemMatcher": [],
      "detail": "Executes database migrations using Alembic."
    }
  ]
}
